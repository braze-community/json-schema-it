{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "lib": ["es2020"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "rootDir": "src",
    "outDir": "cjs",
    "types": ["node", "jest"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "src/**/*.test.ts"]
}
